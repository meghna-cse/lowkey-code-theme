  "version": "0.0.3",
  "publisher": "meghna-cse",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "minimal",
    "low contrast",
    "calm",
    "eye friendly",
    "adhd friendly",
    "color blind friendly"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/meghna-cse/lowkey-code-theme"
  },
  "homepage": "https://github.com/meghna-cse/lowkey-code-theme",
  "bugs": {
    "url": "https://github.com/meghna-cse/lowkey-code-theme/issues"
  },
  "icon": "assets/icon.png",
  "contributes": {
    "themes": [
      {
        "label": "Lowkey Code Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/lowkey-code-dark.json"
      },
      {
        "label": "Lowkey Code Light",
        "uiTheme": "vs",
        "path": "./themes/lowkey-code-light.json"
      }
    ]
